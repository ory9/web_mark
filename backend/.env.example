# PostgreSQL connection URL.
# • Local development: use the standard postgresql:// scheme.
# • Railway: set this to the PUBLIC URL shown in the PostgreSQL service
#   variables panel (used by Prisma migrations and as a fallback).
#   Both postgresql:// and postgres:// schemes are accepted.
DATABASE_URL="postgresql://user:password@localhost:5432/marketplace_db"

# Railway internal private-network URL (optional but recommended on Railway).
# When present the backend uses this instead of DATABASE_URL for all runtime
# queries – it is faster and avoids public-proxy egress costs.
# Example: postgresql://postgres:<password>@<service>.railway.internal:5432/railway
DATABASE_PRIVATE_URL=

JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
REDIS_URL="redis://localhost:6379"
PORT=5000
NODE_ENV="development"
CORS_ORIGIN="http://localhost:3000"
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_REGION="us-east-1"
AWS_S3_BUCKET="your-s3-bucket-name"
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
ADMIN_PASSWORD="change-this-to-a-strong-password"
